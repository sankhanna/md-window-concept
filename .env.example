# Copy to .env.local for local dev, or set these as Project Environment
# Variables in Vercel (Settings → Environment Variables). All are optional —
# config.js falls back to the dev defaults when unset.
#
# Reminder: Vite inlines VITE_* into the public client bundle. Don't put a real
# secret here — MODULEDATA is a low-value dev token only.

VITE_SOCKET_URL=https://cncapi-dev.zillit.com
VITE_CNC_BASE_URL=https://cncapi-dev.zillit.com/api
VITE_MODULEDATA=
